# Headscale configuration example
# Copy to headscale-config/config.yaml and adjust for your deployment.
# Full reference: https://headscale.net/ref/configuration/

# Public URL clients use to reach this control plane.
# Must be HTTPS in production. Use your domain or CF Tunnel hostname.
server_url: "https://headscale.example.com"

listen_addr: "0.0.0.0:8080"
metrics_listen_addr: "0.0.0.0:9090"

grpc_listen_addr: "127.0.0.1:50443"
grpc_allow_insecure: true

noise:
  private_key_path: "/etc/headscale/noise.key"

prefixes:
  v4: 100.64.0.0/10
  v6: fd7a:115c:a1e0::/48
  allocation: sequential

derp:
  server:
    enabled: false
    region_id: 999
    region_code: "headscale"
    region_name: "Headscale Embedded DERP"
    stun_listen_addr: "0.0.0.0:3478"
  # Use Tailscale's public DERP relays via a static map.
  # Set auto_update_enabled: true if the container has unrestricted outbound access.
  auto_update_enabled: false
  update_frequency: 24h
  urls: []
  paths:
    - /etc/headscale/derpmap.yaml

database:
  type: sqlite
  sqlite:
    path: "/var/lib/headscale/db.sqlite"
    write_ahead_log: true

dns:
  magic_dns: true
  # Internal domain for MagicDNS — does not need to be publicly resolvable.
  base_domain: "headscale.internal"
  override_local_dns: false
  nameservers:
    global:
      - 1.1.1.1
      - 8.8.8.8
  extra_records: []

policy:
  mode: file
  path: "/etc/headscale/acls.json"

log:
  level: info
  format: text

unix_socket: /var/lib/headscale/headscale.sock
unix_socket_permission: "0770"

ephemeral_node_inactivity_timeout: 30m
disable_check_updates: false
randomize_client_port: false

logtail:
  enabled: false

taildrop:
  enabled: true
