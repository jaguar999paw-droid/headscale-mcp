# ── headscale-mcp environment ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: Headscale API key
# Generate with: docker exec -it headscale headscale apikeys create
HEADSCALE_API_KEY=

# Recommended: Shared secret protecting the MCP HTTP endpoint
# Generate with: openssl rand -hex 32
MCP_AUTH_TOKEN=changeme

# ── Optional: DuckDNS dynamic DNS ─────────────────────────────────────────
# Only needed if running the duckdns service in docker-compose.yml
# and using the Caddy TLS integration with DuckDNS ACME challenge.
DUCKDNS_SUBDOMAIN=your-subdomain
DUCKDNS_TOKEN=

# ── Optional: Cloudflare Tunnel ────────────────────────────────────────────
# Allows Headscale to be reachable without open inbound ports.
# Create the tunnel at: dash.cloudflare.com → Zero Trust → Networks → Tunnels
# Set the public hostname to point to Service: http://headscale:8080
# Then paste the tunnel token below and update server_url in config.yaml.
CLOUDFLARE_TUNNEL_TOKEN=

# ── Timezone ───────────────────────────────────────────────────────────────
TZ=UTC
